# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/agrimarche

# JWT (obligatoire en production — ne pas utiliser la valeur par défaut)
JWT_SECRET=changez-moi-en-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# Serveur
PORT=8000

# Vercel Blob — stockage des médias (avatars, produits, stories, chat…)
# Créez un store Blob sur vercel.com > Storage, puis copiez le token :
#   vercel env pull   (ou depuis le dashboard Vercel)
BLOB_READ_WRITE_TOKEN=

# AgriBot — IA (optionnel ; sans clé = réponses locales agriculture / plateforme)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
